<script>
jQuery(document).ready(function(){
	
jQuery('.store-locator-row #state option[value="al"]').trigger('click');
	
jQuery('.page-id-895 select[name=fieldname7_1]').change(function(e){
  if (jQuery('select[name=fieldname7_1]').val() == '3'){
			jQuery('#fieldname11_1').val('2');
   
  } else if (jQuery('select[name=fieldname7_1]').val() == '4'){
			jQuery('#fieldname11_1').val('2');
   
  }
	else{
  jQuery('#fieldname11_1').val('Select');
  }
});
});

jQuery(document).ready(function(){
	jQuery('.ui-datepicker').datepicker({
	yearRange: "-100:+0",
});
});


jQuery(document).ready(function(){
jQuery('select[name=fieldname7_1]').change(function(e){
  if (jQuery('select[name=fieldname7_1]').val() == '1'){
			jQuery('.mg_per_day_label label').text('mgeeq/day');
		jQuery('.mg_per_gtt_label label').text('mgeeq/gtt');
   
  }else{
  jQuery('.mg_per_day_label label').text('mg/day');
		jQuery('.mg_per_gtt_label label').text('mg/drop');
  
  }
});
});

jQuery(document).ready(function(){
	jQuery('.biest-resulted-rx').hide();
	jQuery('.testo-resulted-rx').hide();
	jQuery('.prog-resulted-rx').hide();
	jQuery('.dhea-resulted-rx').hide(); 
});

jQuery(document).ready(function(){
		$cu_date = jQuery('#fieldname3_1_date').val();
	   jQuery('#fieldname34_1').val($cu_date); 
	

	jQuery('#fieldname3_date').change(function() {
   jQuery('#fieldname34_1').val(jQuery(this).val()); 
	});
		//$today = date("m/d/Y"); 
//	jQuery('#fieldname117_1').val($today); 
	});

jQuery(document).ready(function(){
    jQuery("#fieldname24_1").click(function(){
			
	var drops_day =	jQuery('.new-rx-drops-day .codepeoplecalculatedfield.field').val();
	var mg_per_ml =  jQuery('.result_mg_ml .codepeoplecalculatedfield.field').val();
	var mg_drop = jQuery("input[name='fieldname20_1']").val();
				 
	//alert("test");
				
			// jQuery(".resulted-rx-header-block").append('hello');
	//jQuery('select[name=fieldname7_1]').change(function(e){
			
		if (jQuery('select[name=fieldname7_1]').val() == '1' && mg_per_ml > 0 && mg_drop > 0){
			
			jQuery('.biest-result-rx-field input.codepeoplecalculatedfield.field').val('mmo Bi-Est ' + mg_per_ml + ' mg/ml ' + '80:20');
				jQuery('.biest-result-sig-field input.codepeoplecalculatedfield.field').val(drops_day + ' (2 drops morning and 3 drops evening)');
				
			jQuery('.biest-resulted-rx').show();
		}
		
	if (jQuery('select[name=fieldname7_1]').val() == '2' && mg_per_ml > 0 && mg_drop > 0){
			
			jQuery('.prog-result-rx-field input.codepeoplecalculatedfield.field').val('mmo Progesterone ' + mg_per_ml + ' mg/ml ');
				jQuery('.prog-result-sig-field input.codepeoplecalculatedfield.field').val(drops_day + ' drops h.s');
		jQuery('.prog-resulted-rx').show();
		

		}
     if (jQuery('select[name=fieldname7_1]').val() == '3' && mg_per_ml > 0 && mg_drop > 0){
			
			jQuery('.testo-result-rx-field input.codepeoplecalculatedfield.field').val('mmo Testosterone ' + mg_per_ml + ' mg/ml ');
				jQuery('.testo-result-sig-field input.codepeoplecalculatedfield.field').val(drops_day + ' drops h.s');
		jQuery('.testo-resulted-rx').show();
		

		}
