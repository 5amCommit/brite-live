<style>
@keyframes popanim {
  0%   {top:0px;}
  50%  {top:20px;}
  100% {top:0px;}
}

.xcolred #field_2-1 fieldset {
 background: red;
}
.xcolgrn #field_2-1 fieldset {
 background: green;
}
.xcolylo #field_2-1 fieldset {
 background: yellow;
}

.page-id-39802 .aiovg-col:first-child {
  width: 66%;
}
.fields.fieldname13_1.cff-dropdown-field.column4 {
 width: 220px !important;
}
.page-id-895 #fieldname24_1, .page-id-922 #fieldname24_1 {
 padding: 4px 18px !important;
 margin-top: 28px;
}
.fields.mg_per_day_label.fieldname57_1.cff-calculated-field.column4 {
 width: 220px !important;
 line-height: 18px;
}
.page-id-923 .fields.custom-rx-value.fieldname23_1.cff-dropdown-field.column4 {
 width: 100% !important;
}
.page-id-923 #field_1-11 {
    width: 100% !important;
    text-align: right;
}
.popmaindv {
 display: flex;
 padding: 60px 0;
}
.popupheading {
 text-align: center;
 font-size: 44px;
 font-family: 'Times New Roman', sans-serif;
}
.popbtnlnk {
 color: #fff;
 font-size: 22px;
 font-family: Arial;
 font-weight: 600;
}
.popbtndv {
 background: #03C973;
 padding: 2% 0;
 border-radius: 30px;
 max-width: 285px;
 margin: 0 auto;
 text-align: center;
}
.popsubdv1 {
 width: 70%;
}
.popsubdv2 {
 width: 30%;
 text-align: center;
}
.popntlk{
 color: #3AC6AB;
 font-size: 24px;
 font-family: Arial;
 font-weight: 600;
 text-align: center;
 cursor: pointer;
}
.popmaindv2 {
  display: flex;
  padding: 0;
  margin-top: 1.75em !important;
}
.popsubdv12 {
  width: 56%;
}
.popsubdv22 {
  width: 44%;
  text-align: center;
}
@media only screen and (max-width: 800px) {
.popmaindv {
 display: block;
 padding: 30px 0;
}
